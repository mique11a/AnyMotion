+def _build_runtime_library_path(extra_entries):
+    entries = []
+    for path in extra_entries:
+        expanded = os.path.abspath(os.path.expanduser(os.path.expandvars(path)))
+        if os.path.isdir(expanded) and expanded not in entries:
+            entries.append(expanded)
+
+    current_ld = os.environ.get("LD_LIBRARY_PATH", "")
+    for path in current_ld.split(os.pathsep):
+        if path and path not in entries:
+            entries.append(path)
+    return os.pathsep.join(entries)
+
