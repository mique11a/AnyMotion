+    def reset_task_costs(self):
+        if self.use_ik_match_table1:
+            for body_name, task in self.human_body_to_task1.items():
+                self._restore_task_cost(task, self.base_task_costs1[body_name])
+        if self.use_ik_match_table2:
+            for body_name, task in self.human_body_to_task2.items():
+                self._restore_task_cost(task, self.base_task_costs2[body_name])
+
+    def _restore_task_cost(self, task, base_costs):
+        base_pos_cost, base_rot_cost = base_costs
+        task.set_position_cost(base_pos_cost)
+        task.set_orientation_cost(base_rot_cost)
+
+    def _scale_task_group(self, task_group, base_cost_group, support_scores):
+        task_scales = self.adaptive_leg_task_weighting.get("task_scales", {})
+        for body_name, task in task_group.items():
+            scale_config = task_scales.get(body_name)
+            if scale_config is None:
+                continue
+
+            support_score = self._resolve_task_support_score(
+                body_name,
+                scale_config,
+                support_scores,
+            )
+            if support_score is None:
+                continue
+
+            pos_scale = self._interpolate_support_scale(
+                support_score,
+                scale_config.get("swing_pos_scale", 1.0),
+                scale_config.get("stance_pos_scale", 1.0),
+            )
+            rot_scale = self._interpolate_support_scale(
+                support_score,
+                scale_config.get("swing_rot_scale", 1.0),
+                scale_config.get("stance_rot_scale", 1.0),
+            )
+            base_pos_cost, base_rot_cost = base_cost_group[body_name]
+            task.set_position_cost(base_pos_cost * pos_scale)
+            task.set_orientation_cost(base_rot_cost * rot_scale)
+
+    def _resolve_task_support_score(self, body_name, scale_config, support_scores):
+        support_metric = scale_config.get("support_metric")
+        if support_metric is not None:
+            support_score = support_scores.get(support_metric)
+        else:
+            support_side = scale_config.get("support_side")
+            if support_side is None:
+                if body_name.startswith("Left"):
+                    support_side = "left"
+                elif body_name.startswith("Right"):
+                    support_side = "right"
+                else:
+                    return None
+
+            support_score = support_scores.get(support_side)
+            override_mode = scale_config.get("support_score_mode")
+            if override_mode is not None:
+                height_score = support_scores.get(f"{support_side}_height_score")
+                speed_score = support_scores.get(f"{support_side}_speed_score")
+                if height_score is not None and speed_score is not None:
+                    override_blend = float(
+                        scale_config.get(
+                            "support_score_blend",
+                            self.adaptive_leg_task_weighting.get("support_score_blend", 0.5),
+                        )
+                    )
+                    support_score = self._compose_support_score(
+                        height_score,
+                        speed_score,
+                        override_mode,
+                        override_blend,
+                    )
+
+        if support_score is None:
+            return None
+
+        support_score = float(np.clip(support_score, 0.0, 1.0))
+        support_score = max(
+            float(scale_config.get("support_score_floor", 0.0)),
+            support_score,
+        )
+        support_score = min(
+            float(scale_config.get("support_score_ceiling", 1.0)),
+            support_score,
+        )
+        support_score_power = float(scale_config.get("support_score_power", 1.0))
+        if support_score_power != 1.0:
+            support_score = float(np.power(np.clip(support_score, 0.0, 1.0), support_score_power))
+        return float(np.clip(support_score, 0.0, 1.0))
+
+    def _interpolate_support_scale(self, support_score, swing_scale, stance_scale):
+        support_score = float(np.clip(support_score, 0.0, 1.0))
+        return float(swing_scale) + support_score * (float(stance_scale) - float(swing_scale))
+
+    def _compose_support_score(self, height_score, speed_score, score_mode, score_blend):
+        height_score = float(np.clip(height_score, 0.0, 1.0))
+        speed_score = float(np.clip(speed_score, 0.0, 1.0))
+        score_blend = float(np.clip(score_blend, 0.0, 1.0))
+
+        if score_mode == "min":
+            return min(height_score, speed_score)
+        if score_mode == "max":
+            return max(height_score, speed_score)
+        return score_blend * height_score + (1.0 - score_blend) * speed_score
+
+    def compute_single_support_metric(self, support_scores):
+        metric_cfg = self.adaptive_leg_task_weighting.get("single_support_metric", {})
+        dominant_support = float(support_scores.get("dominant", 0.0))
+        weak_support = float(support_scores.get("weak", 0.0))
+        support_margin = dominant_support - weak_support
+
+        dominant_support_min = float(metric_cfg.get("dominant_support_min", 0.9))
+        weak_support_max = float(metric_cfg.get("weak_support_max", 0.15))
+        support_margin_min = float(metric_cfg.get("support_margin_min", 0.6))
+
+        dominant_term = np.clip(
+            (dominant_support - dominant_support_min) / max(1.0 - dominant_support_min, 1e-6),
+            0.0,
+            1.0,
+        )
+        weak_term = np.clip(
+            (weak_support_max - weak_support) / max(weak_support_max, 1e-6),
+            0.0,
+            1.0,
+        )
+        margin_term = np.clip(
+            (support_margin - support_margin_min) / max(1.0 - support_margin_min, 1e-6),
+            0.0,
+            1.0,
+        )
+        return float(dominant_term * weak_term * margin_term)
+
+    def _resolve_contact_body_names(self, cfg, side, default_body, fallback_cfg=None):
+        body_names = cfg.get(f"{side}_contact_bodies")
+        if body_names is None and fallback_cfg is not None:
+            body_names = fallback_cfg.get(f"{side}_contact_bodies")
+
+        if body_names is None:
+            body_name = cfg.get(f"{side}_contact_body")
+            if body_name is None and fallback_cfg is not None:
+                body_name = fallback_cfg.get(f"{side}_contact_body")
+            if body_name is None:
+                body_name = default_body
+            body_names = [body_name]
+
+        return [body_name for body_name in body_names if isinstance(body_name, str)]
+
+    def _resolve_contact_point(self, human_data, cfg, side, axis, default_body, fallback_cfg=None):
+        body_names = self._resolve_contact_body_names(cfg, side, default_body, fallback_cfg=fallback_cfg)
+        candidates = []
+        for body_name in body_names:
+            if body_name not in human_data:
+                continue
+            pos = np.asarray(human_data[body_name][0], dtype=np.float64)
+            candidates.append((body_name, pos))
+
+        if not candidates:
+            return None
+
+        mode = cfg.get("contact_body_mode")
+        if mode is None and fallback_cfg is not None:
+            mode = fallback_cfg.get("contact_body_mode")
+        mode = mode or "lowest"
+
+        if mode == "average":
+            positions = np.stack([pos for _, pos in candidates], axis=0)
+            body_name = candidates[0][0]
+            pos = np.mean(positions, axis=0)
+            return {"body_name": body_name, "pos": pos}
+
+        body_name, pos = min(candidates, key=lambda item: item[1][axis])
+        return {"body_name": body_name, "pos": pos.copy()}
+
+    def _compute_contact_speed(self, side, contact_pos, human_data, axis):
+        speed_reference_frame = self.adaptive_leg_task_weighting.get("speed_reference_frame", "world")
+        speed_ignore_height_axis = bool(
+            self.adaptive_leg_task_weighting.get("speed_ignore_height_axis", False)
+        )
+
+        reference_pos = np.asarray(contact_pos, dtype=np.float64).copy()
+        if speed_reference_frame == "root_relative" and self.human_root_name in human_data:
+            root_pos = np.asarray(human_data[self.human_root_name][0], dtype=np.float64)
+            reference_pos = reference_pos - root_pos
+
+        if speed_ignore_height_axis:
+            reference_pos = np.delete(reference_pos, axis)
+
+        prev_pos = self.adaptive_leg_prev_positions.get(side)
+        speed = 0.0 if prev_pos is None else float(np.linalg.norm(reference_pos - prev_pos))
+        self.adaptive_leg_prev_positions[side] = reference_pos.copy()
+        return speed
+
+    def compute_leg_support_scores(self, human_data):
+        axis = int(self.adaptive_leg_task_weighting.get("height_axis", 2))
+        stance_height = float(self.adaptive_leg_task_weighting.get("stance_height", 0.015))
+        swing_height = float(self.adaptive_leg_task_weighting.get("swing_height", 0.08))
+        stance_speed = float(self.adaptive_leg_task_weighting.get("stance_speed", 0.004))
+        swing_speed = float(self.adaptive_leg_task_weighting.get("swing_speed", 0.012))
+        score_blend = float(self.adaptive_leg_task_weighting.get("support_score_blend", 0.5))
+        score_smoothing = float(self.adaptive_leg_task_weighting.get("score_smoothing", 0.0))
+        score_mode = self.adaptive_leg_task_weighting.get("support_score_mode", "blend")
+        score_blend = float(np.clip(score_blend, 0.0, 1.0))
+        score_smoothing = float(np.clip(score_smoothing, 0.0, 0.95))
+        left_contact = self._resolve_contact_point(
+            human_data,
+            self.adaptive_leg_task_weighting,
+            "left",
+            axis,
+            "LeftFootMod",
+        )
+        right_contact = self._resolve_contact_point(
+            human_data,
+            self.adaptive_leg_task_weighting,
+            "right",
+            axis,
+            "RightFootMod",
+        )
+        if left_contact is None or right_contact is None:
+            return {}
+
+        left_pos = left_contact["pos"]
+        right_pos = right_contact["pos"]
+        lowest_height = min(left_pos[axis], right_pos[axis])
+
+        support_scores = {}
+        for side, pos in (
+            ("left", left_pos),
+            ("right", right_pos),
+        ):
+            speed = self._compute_contact_speed(side, pos, human_data, axis)
+
+            rel_height = float(pos[axis] - lowest_height)
+            height_score = 1.0 - np.clip(
+                (rel_height - stance_height) / max(swing_height - stance_height, 1e-6),
+                0.0,
+                1.0,
+            )
+            speed_score = 1.0 - np.clip(
+                (speed - stance_speed) / max(swing_speed - stance_speed, 1e-6),
+                0.0,
+                1.0,
+            )
+            height_key = f"{side}_height_score"
+            prev_height_score = self.adaptive_leg_component_state.get(height_key, height_score)
+            smooth_height_score = score_smoothing * prev_height_score + (1.0 - score_smoothing) * height_score
+            smooth_height_score = float(np.clip(smooth_height_score, 0.0, 1.0))
+            self.adaptive_leg_component_state[height_key] = smooth_height_score
+            support_scores[height_key] = smooth_height_score
+
+            speed_key = f"{side}_speed_score"
+            prev_speed_score = self.adaptive_leg_component_state.get(speed_key, speed_score)
+            smooth_speed_score = score_smoothing * prev_speed_score + (1.0 - score_smoothing) * speed_score
+            smooth_speed_score = float(np.clip(smooth_speed_score, 0.0, 1.0))
+            self.adaptive_leg_component_state[speed_key] = smooth_speed_score
+            support_scores[speed_key] = smooth_speed_score
+
+            raw_score = self._compose_support_score(
+                height_score,
+                speed_score,
+                score_mode,
+                score_blend,
+            )
+            prev_score = self.adaptive_leg_support_state.get(side, raw_score)
+            support_score = score_smoothing * prev_score + (1.0 - score_smoothing) * raw_score
+            support_score = float(np.clip(support_score, 0.0, 1.0))
+            self.adaptive_leg_support_state[side] = support_score
+            support_scores[side] = support_score
+
+        return support_scores
             
