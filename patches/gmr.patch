+            right_score = float(support_scores.get("right", 0.0))
+            support_scores["dominant"] = max(left_score, right_score)
+            support_scores["weak"] = min(left_score, right_score)
+            support_scores["single_support"] = self.compute_single_support_metric(support_scores)
+        self.latest_leg_support_scores = support_scores
+        return support_scores
