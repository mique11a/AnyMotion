+    def lock_human_root_heading(self, human_data, support_scores=None):
+        if not self.root_heading_lock.get("enabled", False):
+            return human_data
+        if self.human_root_name not in human_data:
+            return human_data
+
+        mode = self.root_heading_lock.get("mode", "initial")
+        if mode != "initial":
+            raise ValueError(f"Unsupported human_root_heading_lock mode: {mode}")
+
+        strength = self.compute_root_heading_lock_strength(support_scores)
+
+        root_pos, root_quat = human_data[self.human_root_name]
+        root_rot = R.from_quat(root_quat, scalar_first=True)
+        yaw, pitch, roll = root_rot.as_euler("zyx", degrees=False)
+
+        if self.root_heading_reference is None:
+            reference_deg = self.root_heading_lock.get("reference_deg", None)
+            self.root_heading_reference = (
+                np.deg2rad(float(reference_deg)) if reference_deg is not None else float(yaw)
+            )
+
+        yaw_delta = np.arctan2(
+            np.sin(yaw - self.root_heading_reference),
+            np.cos(yaw - self.root_heading_reference),
+        )
+        locked_yaw = self.root_heading_reference + (1.0 - strength) * yaw_delta
+        locked_rot = R.from_euler("zyx", [locked_yaw, pitch, roll], degrees=False)
+
+        locked_human_data = human_data.copy()
+        locked_human_data[self.human_root_name] = [
+            np.asarray(root_pos, dtype=np.float64).copy(),
+            locked_rot.as_quat(scalar_first=True),
+        ]
+        return locked_human_data
