+    def compute_root_heading_lock_strength(self, support_scores):
+        base_strength = float(self.root_heading_lock.get("strength", 1.0))
+        base_strength = float(np.clip(base_strength, 0.0, 1.0))
+
+        adaptive_cfg = self.root_heading_lock.get("adaptive_single_support", {})
+        if not adaptive_cfg.get("enabled", False) or not support_scores:
+            self.root_heading_lock_strength = base_strength
+            self.latest_root_heading_lock_strength = base_strength
+            return base_strength
+
+        dominant_support = max(float(score) for score in support_scores.values())
+        weak_support = min(float(score) for score in support_scores.values())
+        support_margin = dominant_support - weak_support
+
+        dominant_support_min = float(adaptive_cfg.get("dominant_support_min", 0.8))
+        swing_support_max = float(adaptive_cfg.get("swing_support_max", 0.25))
+        support_margin_min = float(adaptive_cfg.get("support_margin_min", 0.35))
+        max_strength = float(adaptive_cfg.get("max_strength", 1.0))
+        strength_smoothing = float(adaptive_cfg.get("strength_smoothing", 0.0))
+        strength_smoothing = float(np.clip(strength_smoothing, 0.0, 0.95))
+
+        dominant_term = np.clip(
+            (dominant_support - dominant_support_min) / max(1.0 - dominant_support_min, 1e-6),
+            0.0,
+            1.0,
+        )
+        weak_term = np.clip(
+            (swing_support_max - weak_support) / max(swing_support_max, 1e-6),
+            0.0,
+            1.0,
+        )
+        margin_term = np.clip(
+            (support_margin - support_margin_min) / max(1.0 - support_margin_min, 1e-6),
+            0.0,
+            1.0,
+        )
+        single_support_score = dominant_term * weak_term * margin_term
+        target_strength = base_strength + single_support_score * (max_strength - base_strength)
+
+        if self.root_heading_lock_strength is None:
+            filtered_strength = target_strength
+        else:
+            filtered_strength = (
+                strength_smoothing * self.root_heading_lock_strength
+                + (1.0 - strength_smoothing) * target_strength
+            )
+
+        filtered_strength = float(np.clip(filtered_strength, 0.0, 1.0))
+        self.root_heading_lock_strength = filtered_strength
+        self.latest_root_heading_lock_strength = filtered_strength
+        return filtered_strength
+
+    def apply_adaptive_ground_alignment(self, human_data, support_scores=None):
+        if not self.adaptive_ground_alignment.get("enabled", False):
+            self.latest_ground_alignment_shift = 0.0
+            self.ground_alignment_shift = None
+            return human_data
+
+        axis = int(self.adaptive_ground_alignment.get("height_axis", 2))
+        left_contact = self._resolve_contact_point(
+            human_data,
+            self.adaptive_ground_alignment,
+            "left",
+            axis,
+            "LeftFootMod",
+            fallback_cfg=self.adaptive_leg_task_weighting,
+        )
+        right_contact = self._resolve_contact_point(
+            human_data,
+            self.adaptive_ground_alignment,
+            "right",
+            axis,
+            "RightFootMod",
+            fallback_cfg=self.adaptive_leg_task_weighting,
+        )
+        if left_contact is None or right_contact is None:
+            self.latest_ground_alignment_shift = 0.0
+            return human_data
+
+        target_height = float(self.adaptive_ground_alignment.get("target_height", 0.0))
+        alignment_strength = float(self.adaptive_ground_alignment.get("alignment_strength", 1.0))
+        offset_smoothing = float(self.adaptive_ground_alignment.get("offset_smoothing", 0.0))
+        offset_smoothing = float(np.clip(offset_smoothing, 0.0, 0.95))
+        max_shift = float(self.adaptive_ground_alignment.get("max_shift", np.inf))
+        reference_mode = self.adaptive_ground_alignment.get("reference_mode", "lowest")
+
+        left_height = float(left_contact["pos"][axis])
+        right_height = float(right_contact["pos"][axis])
+        if reference_mode == "support_weighted" and support_scores:
+            left_weight = float(support_scores.get("left", 0.0))
+            right_weight = float(support_scores.get("right", 0.0))
+            total_weight = left_weight + right_weight
+            if total_weight > 1e-6:
+                reference_height = (left_weight * left_height + right_weight * right_height) / total_weight
+            else:
+                reference_height = min(left_height, right_height)
+        else:
+            reference_height = min(left_height, right_height)
+
+        activation_metric = self.adaptive_ground_alignment.get("activation_metric", "dominant")
+        activation = 1.0 if not support_scores else float(support_scores.get(activation_metric, 1.0))
+        activation_min = float(self.adaptive_ground_alignment.get("activation_min", 0.0))
+        activation_max = float(self.adaptive_ground_alignment.get("activation_max", 1.0))
+        if activation_max <= activation_min:
+            activation_scale = 1.0 if activation >= activation_max else 0.0
+        else:
+            activation_scale = float(
+                np.clip((activation - activation_min) / (activation_max - activation_min), 0.0, 1.0)
+            )
+        activation_floor = float(self.adaptive_ground_alignment.get("activation_floor", 0.0))
+        activation_scale = max(activation_floor, activation_scale)
+
+        target_shift = max(reference_height - target_height, 0.0)
+        target_shift = min(target_shift * alignment_strength * activation_scale, max_shift)
+
+        if self.ground_alignment_shift is None:
+            filtered_shift = target_shift
+        else:
+            filtered_shift = (
+                offset_smoothing * self.ground_alignment_shift
+                + (1.0 - offset_smoothing) * target_shift
+            )
+        filtered_shift = float(np.clip(filtered_shift, 0.0, max_shift))
+        self.ground_alignment_shift = filtered_shift
+        self.latest_ground_alignment_shift = filtered_shift
+
+        aligned_human_data = {}
+        for body_name, (pos, quat) in human_data.items():
+            aligned_human_data[body_name] = [
+                np.asarray(pos, dtype=np.float64).copy() - np.eye(3, dtype=np.float64)[axis] * filtered_shift,
+                quat,
+            ]
+        return aligned_human_data
+
+    def apply_adaptive_task_weighting(self, human_data, support_scores=None):
+        self.reset_task_costs()
+        if not self.adaptive_leg_task_weighting.get("enabled", False):
+            self.latest_leg_support_scores = {}
+            return
+
+        if support_scores is None:
+            support_scores = self.compute_leg_support_scores(human_data)
+        self.latest_leg_support_scores = support_scores
+        if not support_scores:
+            return
